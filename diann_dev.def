Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update && apt-get install -y \
        wget \
        libgomp1 \
        libstdc++6 \
        locales \
        ca-certificates

    locale-gen en_US.UTF-8

%environment
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8

%runscript
    exec "$@"
