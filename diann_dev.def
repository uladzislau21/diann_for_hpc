Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update && apt-get install -y \
        wget \
        libgomp1 \
        libstdc++6 \
        locales \
        ca-certificates

    locale-gen en_US.UTF-8

    wget https://builds.dotnet.microsoft.com/dotnet/Sdk/8.0.420/dotnet-sdk-8.0.420-linux-x64.tar.gz -O /tmp/dotnet-sdk-8.0.420-linux-x64.tar.gz
    mkdir -p /opt/dotnet && tar zxf /tmp/dotnet-sdk-8.0.420-linux-x64.tar.gz -C /opt/dotnet

    wget https://github.com/vdemichev/DiaNN/releases/download/2.0/DIA-NN-2.5.1-Academia-Linux.zip -O /tmp/dian.zip
    unzip /tmp/diann.zip -d /usr/local/bin/
    chmod +x /usr/local/bin/diann-linux

%environment
    export DOTNET_ROOT=/opt/dotnet
    export PATH=$PATH:/opt/dotnet
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8

%runscript
    exec diann-linux "$@"
